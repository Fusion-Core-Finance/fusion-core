# fUSD keeper suite environment — copied to /etc/fusd/keeper.env by install.sh (chmod 600).
# Loaded by every unit; the monitor only reads the RPC URL (it runs on a throwaway wallet).

# RPC endpoint. Needs getProgramAccounts for the liquidator scan (Helius/Triton paid tiers do).
ANCHOR_PROVIDER_URL=https://mainnet.helius-rpc.com/?api-key=YOUR-KEY

# Fee-payer for oracle-crank + liquidator. Create fresh, fund ~1 SOL, keep SEPARATE from the
# gov/deployer wallet:  solana-keygen new -o /etc/fusd/keeper.json --no-bip39-passphrase
ANCHOR_WALLET=/etc/fusd/keeper.json

# Priority fee per CU for crank sends (u-lamports; default 20000 if unset). The cranks are not
# latency-critical — 1000-2500 is plenty off-peak.
#PRIORITY_FEE_MICROLAMPORTS=2000

# Oracle-crank config file (markets + interval overrides, e.g. sbIntervalSecs). Same pattern as
# MONITOR_CONFIG: lets you tune cadences without touching the systemd unit. Unset = built-in
# WSOL default. NOTE: Switchboard charges ~0.0009 SOL per update — sbIntervalSecs is the cost knob.
#CRANK_CONFIG=/etc/fusd/crank.json

# Webhook for critical alerts + monitor liveness. Two flavors, picked by the URL:
#   Telegram: WEBHOOK_URL=https://api.telegram.org/bot<TOKEN>/sendMessage  (+ TELEGRAM_CHAT_ID)
#   Discord:  WEBHOOK_URL=https://discord.com/api/webhooks/...
WEBHOOK_URL=REPLACE-ME
#TELEGRAM_CHAT_ID=
MONITOR_URL=http://127.0.0.1:8787
STATE_FILE=/var/lib/fusd/alert-state
