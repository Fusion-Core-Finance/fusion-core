# Rust / Anchor
/target
**/*.rs.bk
Cargo.lock.bak

# Anchor
.anchor
test-ledger
**/.DS_Store

# Certora prover local working/output dir (large; regenerated per run — never commit)
.certora_internal/

# cargo-mutants working/output dirs (large; regenerated per run — never commit; the reproducible
# inputs are crates/fusd-math/mutants.toml + scripts/mutants-fusd-math.sh, which ARE committed)
/mutants.out/
/mutants.out.old/

# Node / TS
node_modules
dist
build
*.tsbuildinfo

# Keys & secrets — NEVER commit (the dev program keypair lives under target/deploy, ignored)
/keys/
*.pem
*keypair*.json
.env
.env.*

# Logs
*.log

# Claude Code session / memory data (never commit)
.claude/

# Fetched program binaries for PoC test fixtures (re-create via scripts/fetch-*.sh)
/fixtures/

# proptest writes deterministic failure-repro seeds here on a counterexample; nothing
# should fail in CI, and we do not commit them.
proptest-regressions/

# Local-only session memory (never commit to the public repo)
/CLAUDE.md
/.internal/

# Vendored fork build artifacts (own workspace, own target dir)
/vendor/spl-stake-pool/target/
